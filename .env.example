# ============================================================
# AI求职打印服务终端 - 环境变量示例
# 复制本文件为 .env，填入真实值，不要提交 .env 到 Git
# ============================================================

# ------ 前端（VITE_ 前缀才会暴露给浏览器） ------
VITE_API_BASE_URL=http://localhost:3000

# ------ 对象存储后端（腾讯云 COS，仅服务端读取，禁止加 VITE_ 前缀） ------
# 权威配置见 services/api/.env.example；此处为部署总览。
# 存储后端选择：local(默认，文件落本地 FS) | cos(文件落腾讯云 COS，预签名 URL 上传/下载)
# 生产必须显式设为 cos 并填齐下方 4 项，否则会静默回落 local（文件只落本机磁盘）——上线风险，务必确认。
FILE_STORAGE_DRIVER=cos

# COS 凭证（来自腾讯云 CAM 访问密钥；仅服务端持有，严禁提交真实值）
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
# 统一私有桶 + region；按 objectKey 前缀分类，不按端拆桶
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=
# 签名 URL 有效期（秒）；合规上限 1800（30 分钟），超过会被 clamp
TENCENT_COS_SIGN_URL_EXPIRES_SECONDS=1800

# 本地开发回落本地 FS：将 FILE_STORAGE_DRIVER 改为 local，文件落 FILE_STORAGE_DIR（空则 cwd/storage）
# FILE_STORAGE_DRIVER=local
# FILE_STORAGE_DIR=

# ------ 奔图打印机（仅服务端，禁止加 VITE_ 前缀） ------
PANTUM_APP_KEY=
PANTUM_APP_SECRET=
PANTUM_CALLBACK_URL=

# ------ 数据库 ------
DATABASE_URL=postgresql://user:password@localhost:5432/ai_job_print

# ------ Redis ------
REDIS_URL=redis://localhost:6379

# ------ 后端服务 ------
NODE_ENV=development
PORT=3000
JWT_SECRET=
# 凭证加密密钥（AES-256-GCM，用于数据源 apiSecret/webhookSecret 落库加密）。
# secret-cipher.ts 缺失即抛错；生产须为高强度随机值。
SECRET_ENCRYPTION_KEY=
# 文件签名密钥（HMAC，用于打印/上传临时签名 URL）。signing.ts 缺失即抛错。
FILE_SIGNING_SECRET=
# 支付会话签名密钥（HMAC，用于打印订单出码/轮询短期 token）。生产必须独立配置且不少于 32 字符。
PAYMENT_SESSION_SECRET=

# ------ Windows Terminal Agent（本地配置，不提交） ------
TERMINAL_ID=
AGENT_API_BASE_URL=
AGENT_HEARTBEAT_INTERVAL_MS=30000
TERMINAL_ADMIN_SECRET=
TERMINAL_ACTION_TOKEN_SECRET=
