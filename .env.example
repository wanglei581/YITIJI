# ============================================================
# AI求职打印服务终端 - 环境变量示例
# 复制本文件为 .env，填入真实值，不要提交 .env 到 Git
# ============================================================

# ------ 前端（VITE_ 前缀才会暴露给浏览器） ------
VITE_API_BASE_URL=http://localhost:3000

# ------ 对象存储（阿里云 OSS / 腾讯 COS / MinIO） ------
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=
OSS_ENDPOINT=

# ------ 奔图打印机（仅服务端，禁止加 VITE_ 前缀） ------
PANTUM_APP_KEY=
PANTUM_APP_SECRET=
PANTUM_CALLBACK_URL=

# ------ 数据库 ------
DATABASE_URL=postgresql://user:password@localhost:5432/ai_job_print

# ------ Redis ------
REDIS_URL=redis://localhost:6379

# ------ 后端服务 ------
NODE_ENV=development
PORT=3000
JWT_SECRET=
# 凭证加密密钥（AES-256-GCM，用于数据源 apiSecret/webhookSecret 落库加密）。
# secret-cipher.ts 缺失即抛错；生产须为高强度随机值。
SECRET_ENCRYPTION_KEY=
# 文件签名密钥（HMAC，用于打印/上传临时签名 URL）。signing.ts 缺失即抛错。
FILE_SIGNING_SECRET=

# ------ Windows Terminal Agent（本地配置，不提交） ------
TERMINAL_ID=
AGENT_API_BASE_URL=
AGENT_HEARTBEAT_INTERVAL_MS=30000
TERMINAL_ADMIN_SECRET=
TERMINAL_ACTION_TOKEN_SECRET=
