{
  "name": "ai-job-print-terminal",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20.19",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "concurrently --names kiosk,admin,partner --prefix-colors blue,green,yellow \"pnpm --filter ./apps/kiosk dev\" \"pnpm --filter ./apps/admin dev\" \"pnpm --filter ./apps/partner dev\"",
    "dev:kiosk": "pnpm --filter ./apps/kiosk dev",
    "dev:admin": "pnpm --filter ./apps/admin dev",
    "dev:partner": "pnpm --filter ./apps/partner dev",
    "build:kiosk:production": "pnpm --filter @ai-job-print/kiosk build && pnpm --filter @ai-job-print/kiosk verify:prod-build-config",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\" --ignore-path .prettierignore",
    "clean": "rimraf \"apps/*/dist\" \"packages/*/dist\" \"apps/*/vite.config.js\" \"apps/*/vite.config.d.ts\" \"apps/*/tsconfig.tsbuildinfo\""
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.15.0"
  },
  "pnpm": {
    "overrides": {
      "qs": "6.15.2",
      "@hono/node-server": "2.0.4",
      "uuid": "14.0.0"
    }
  }
}
