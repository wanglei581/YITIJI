    "@prisma/client": "^7.8.0",
    "@types/express": "^5.0.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.77.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.15.2",
