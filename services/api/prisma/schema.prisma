// Prisma schema — Phase 8.2A (Prisma v7 format)
//
// Database URL is configured in prisma.config.ts, not here.
// Local dev:  DATABASE_URL="file:./prisma/dev.db"  (SQLite)
// Production: DATABASE_URL="postgresql://..."       (PostgreSQL, change provider)
//
// Generated client is at: src/generated/prisma/
// Import as: import { PrismaClient } from '../generated/prisma'

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Terminal ──────────────────────────────────────────────────────────────────

model Terminal {
  id                String   @id
  terminalCode      String   @unique
  agentToken        String   @unique
  deviceFingerprint String
  registeredAt      DateTime @default(now())
  lastSeenAt        DateTime @updatedAt

  heartbeats TerminalHeartbeat[]
  printTasks PrintTask[]
}

// ── PrintTask ─────────────────────────────────────────────────────────────────
// status values: "pending" | "claimed" | "printing" | "completed" | "failed"
// Terminal states (completed / failed) must never be overwritten.

model PrintTask {
  id           String    @id
  terminalId   String?
  terminal     Terminal? @relation(fields: [terminalId], references: [id])
  endUserId    String?
  endUser      EndUser?  @relation(fields: [endUserId], references: [id], onDelete: SetNull)
  fileUrl      String
  fileMd5      String
  paramsJson   String    @default("{}")
  status       String    @default("pending")
  claimedAt    DateTime?
  claimExpiry  DateTime?
  completedAt  DateTime?
  errorCode    String?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  statusLogs PrintTaskStatusLog[]

  @@index([endUserId])
}

// ── TerminalHeartbeat ─────────────────────────────────────────────────────────

model TerminalHeartbeat {
  id            String   @id @default(cuid())
  terminalId    String
  terminal      Terminal @relation(fields: [terminalId], references: [id])
  printerStatus String?
  agentVersion  String?
  ipAddress     String?
  diskFreeGb    Float?
  createdAt     DateTime @default(now())
}

// ── PrintTaskStatusLog ────────────────────────────────────────────────────────

model PrintTaskStatusLog {
  id         String    @id @default(cuid())
  taskId     String
  task       PrintTask @relation(fields: [taskId], references: [id])
  fromStatus String
  toStatus   String
  errorCode  String?
  createdAt  DateTime  @default(now())
}

// ── Organization ──────────────────────────────────────────────────────────────
// Phase 0b: 合作机构主体。Partner 账号(User.role='partner')必须挂在某个 org 下,
// 上传的 Job/JobSource 也以 orgId 做硬隔离。
//
// type 取值同 packages/shared PartnerType:
//   'school_employment_center' | 'public_employment_service' |
//   'licensed_hr_agency' | 'fair_organizer' | 'enterprise_source'

model Organization {
  id         String   @id
  name       String
  type       String
  contact    String?
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users      User[]
  jobs       Job[]      @relation("JobOrg")
  jobSources JobSource[]
  jobFairs   JobFair[]  @relation("FairOrg")
}

// ── User ──────────────────────────────────────────────────────────────────────
// Phase 0b: 后台登录账号,替换 0a 的 DEV_USERS 硬编码。
// role 取值见 packages/shared/UserRole:
//   'admin' | 'partner' | 'kiosk'
// admin/kiosk 角色 orgId 为 null;partner 必须有 orgId。

model User {
  id           String        @id @default(cuid())
  username     String        @unique
  passwordHash String
  name         String
  role         String        // 见 UserRole
  orgId        String?
  org          Organization? @relation(fields: [orgId], references: [id])
  enabled      Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  uploadedFiles FileObject[] @relation("FileUploader")
  auditLogs     AuditLog[]

  @@index([orgId])
}

// ── EndUser ─────────────────────────────────────────────────────────────────
// 阶段 A: C 端求职者账号。手机号验证码登录;不存明文手机号。
//   phoneHash: HMAC-SHA256(手机号) 唯一查找键
//   phoneEnc:  AES-256-GCM 加密手机号,仅服务端可解,用于派生脱敏展示
// 与内部运营 User 表完全独立,不参与企业招聘闭环。

model EndUser {
  id          String    @id @default(cuid())
  phoneHash   String    @unique
  phoneEnc    String
  nickname    String?
  enabled     Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  files           FileObject[]
  aiResumeResults AiResumeResult[]
  printTasks      PrintTask[]
}

// ── JobSource ─────────────────────────────────────────────────────────────────
// Phase 0b: 一个机构可配多个数据源,按 sourceKind × accessMode 双维度刻画。
//
// sourceKind:'job_platform' | 'hr_company' | 'school' | 'fair_organizer' | 'aggregator' | 'manual'
// accessMode:'api' | 'excel' | 'csv' | 'json' | 'webhook' | 'manual'
//
// 敏感凭证(apiSecret / accessToken / clientSecret)绝不存在此表,
// 走独立的服务端 secret store(后续阶段引入)。

model JobSource {
  id             String        @id @default(cuid())
  orgId          String
  org            Organization  @relation(fields: [orgId], references: [id])
  name           String
  sourceKind     String
  accessMode     String
  syncFreq       String        @default("manual")
  enabled        Boolean       @default(true)
  description    String?
  lastSyncAt     DateTime?
  lastSyncStatus String?

  // ── W3 BE-8 同步接入(P0)──────────────────────────────────
  // accessMode='api' 时:endpoint + authType + encryptedCredential 三件必填
  // accessMode='webhook' 时:webhookSecret 必填(企业用解密后的原文 HMAC 签名 payload)
  // 任一字段都不返回前端原文,前端只见 credentialConfigured: boolean。

  /** API 模式的接入地址,例 "https://api.zhilian.com/v2/jobs" */
  endpoint            String?
  /** 'bearer' | 'oauth2' | 'api_key' | 'basic' | 'custom' */
  authType            String?
  /** AES-256-GCM 加密后的凭证字符串。详见 src/common/crypto/secret-cipher.ts */
  encryptedCredential String?
  /** AES-256-GCM 加密后的 Webhook 签名密钥。只在服务端解密用于 HMAC 校验。 */
  webhookSecret       String?
  /** Webhook 密钥上次轮换时间,审计用 */
  webhookSecretRotatedAt DateTime?
  /** W8 API pull worker 响应解析配置(JSON)。
   *  { dataType:'job'|'fair', rootPath?:string, fields?:Record<string,string> }
   *  rootPath: 点分路径到数据数组,如 "data.jobs"、"items"，空则 auto-detect。
   *  fields: 标准字段 → 源字段名映射，如 { "externalId":"id","title":"position" }。
   *  为 null 时按 auto-detect 逻辑处理(源字段名与标准字段名相同)。
   */
  responseConfig String?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  jobs          Job[]
  syncLogs      SyncLog[]
  importBatches ImportBatch[]
  fieldMappingRules FieldMappingRule[]
  fairs         JobFair[]  @relation("FairSource")

  @@index([orgId])
}

// ── Job ───────────────────────────────────────────────────────────────────────
// Phase 0b: 外部同步的岗位信息(信息入口,非招聘闭环)。
//
// 合规硬约束(CLAUDE.md §10):
//   sourceOrgId / externalId / sourceUrl / sourceName 必填
//   reviewStatus 默认 'pending',通过审核(approved)+ publishStatus='published' 才在 C 端可见
//   @@unique(sourceOrgId, externalId) 防同一机构重复导入
//
// reviewStatus:  'pending' | 'reviewing' | 'approved' | 'rejected'
// publishStatus: 'draft' | 'published' | 'unpublished' | 'expired'
// tagsJson:      JSON 字符串,SQLite 无原生 array;读取时 JSON.parse,
//                Postgres 切换后可改 String[]。

model Job {
  id   String @id @default(cuid())

  // 来源(合规必填)
  sourceOrgId String
  org         Organization @relation("JobOrg", fields: [sourceOrgId], references: [id])
  sourceId    String?
  source      JobSource?   @relation(fields: [sourceId], references: [id])
  externalId  String
  sourceName  String
  sourceUrl   String

  // 岗位信息
  title        String
  company      String
  city         String
  category     String?  // 'fulltime' | 'intern' | 'campus' | 'parttime'
  salary       String?
  description  String?
  requirements String?
  tagsJson     String   @default("[]")

  // 审核/发布
  reviewStatus  String @default("pending")
  publishStatus String @default("draft")

  // 审计字段(Phase #4):
  //   - reviewedBy:执行 approve/reject 的 admin User.id
  //   - reviewedAt:审核动作发生时间
  //   - rejectReason:被拒原因(reject 时必填,approve 时清空)
  reviewedBy   String?
  reviewedAt   DateTime?
  rejectReason String?

  syncTime  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceOrgId, externalId])
  @@index([sourceOrgId])
  @@index([sourceId])
  @@index([reviewStatus, publishStatus])
}

// ── FileObject ────────────────────────────────────────────────────────────────
// BE-1(P0 W1):用户文件元数据 + 隐私自动清理。
//
// 合规约束(CLAUDE.md §11):
//   - 简历 / 身份证 / 证件照 / 求职材料等敏感文件设有效期,过期自动清理
//   - 文件 URL 走 HMAC 签名 + 短 TTL(5 分钟),严禁公开持久 URL
//   - 物理文件按 storageKey 落地(本地 FS 起步:./storage/<storageKey>,
//     上线后可切 MinIO/OSS,storageKey 不变)
//   - deletedAt 软删 + 物理清理通过 cron 完成,管理员手动清理同样走此路径
//   - 所有访问 / 清理动作必须经 AuditLog 记录
//
// purpose 取值:
//   'resume_upload'   — 求职者上传的简历(高敏)
//   'resume_scan'     — Kiosk 扫描的纸质简历(高敏)
//   'id_scan'         — 身份证 / 证件照(高敏)
//   'print_doc'       — 通用打印文档(普通)
//   'fair_material'   — 招聘会资料 / 模板素材(普通)
//   'cover_letter'    — 求职信 / 推荐信(普通)
//
// sensitiveLevel:
//   'normal'           — 默认 24h 过期
//   'sensitive'        — 简历类,默认 6h 过期
//   'highly_sensitive' — 身份证类,默认 1h 过期(分析完即删)

model FileObject {
  id          String  @id @default(cuid())
  // storageKey 即对象存储 objectKey(COS:users/.../{id}.{ext};本地:同键落 FS)。
  storageKey  String  @unique

  // ── COS 接入:落库存储位置(provenance + 跨后端路由)─────────────────
  //   bucket:COS 私有桶名;本地后端用哨兵 'local-fs'。
  //   region:如 'ap-guangzhou';本地用 'local'。
  //   读 / 删 / 签名按此 bucket 路由后端,兼容"先本地后切 COS"的历史数据。
  bucket      String  @default("local-fs")
  region      String  @default("local")

  // 元数据
  filename    String   // 原始文件名(originalName);绝不作为 objectKey
  mimeType    String
  sizeBytes   Int
  sha256      String   // 服务端直传路径就 buffer 计算;直传意图未知时为 ''

  // 业务关联 / 归属
  uploaderId  String?  // 后台 User(admin/partner)上传者
  uploader    User?   @relation("FileUploader", fields: [uploaderId], references: [id])
  endUserId   String?
  endUser     EndUser? @relation(fields: [endUserId], references: [id], onDelete: SetNull)
  // ownerType:'user' | 'partner' | 'admin' | 'system'(授权与 objectKey 前缀维度)
  ownerType   String?
  // ownerId:user→endUserId / partner→orgId / admin→userId;匿名 / system 为 null
  ownerId     String?
  purpose     String
  sensitiveLevel String @default("normal")
  // visibility:'private' | 'internal' | 'public'(默认 private,合规安全)
  visibility  String  @default("private")
  // status:'uploading' | 'active' | 'quarantined' | 'deleted'
  status      String  @default("active")
  createdBy   String?

  // 隐私 / 清理
  expiresAt   DateTime
  deletedAt   DateTime?
  deletedBy   String?  // 'auto' | 'admin:<userId>' | 'user'
  deleteReason String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([uploaderId])
  @@index([endUserId])
  @@index([ownerType, ownerId])
  @@index([purpose])
  @@index([status])
  @@index([expiresAt])
  @@index([deletedAt])
}

// ── AuditLog ──────────────────────────────────────────────────────────────────
// BE-2(P0 W2):管理员操作审计日志。
//
// 合规约束(CLAUDE.md §11/§12):
//   - 任何 admin / partner 写操作必须落审计
//   - 同步写入(不走异步队列),保证 demo 时点击强制清理立即看到日志
//   - 不可删除,不可篡改(数据库层无 DELETE / UPDATE 权限,业务层永不暴露)
//   - 保留期 ≥ 180 天(由独立归档作业搬运,不在业务库删)
//
// action 命名规范:'<resource>.<verb>',例:'file.force_delete' / 'job.review'
//
// targetType:'file' | 'job' | 'job_source' | 'organization' | 'user' | 'fair' | 'system'
// targetId:被操作资源的主键(可选,系统级动作为 null)

// ── JobFair ───────────────────────────────────────────────────────────────────
// BE-7(P0 W2):招聘会 + 校企合作(主题变体)。
//
// 合规约束:
//   - sourceOrgId / externalId / sourceUrl / sourceName 必填(同 Job)
//   - reviewStatus 默认 'pending',approve + publish 才在 C 端可见
//   - 不存"预约人列表"等候选人数据(预约走第三方,我方只跳转)
//
// theme:
//   'general'      普通校招/社招招聘会
//   'campus'       高校校园招聘会
//   'campus_corp'  校企合作主题展(秒哒 kiosk/30-32,catalog Q1 结论)
//   'industry'     行业专场(秒哒 partner/12 的 AI 人工智能专场)
//
// reviewStatus  / publishStatus 取值与 Job 完全一致(详见 Job model 上方注释)。

model JobFair {
  id   String @id @default(cuid())

  // 来源(合规必填)
  sourceOrgId String
  org         Organization @relation("FairOrg", fields: [sourceOrgId], references: [id])
  externalId  String
  sourceName  String
  sourceUrl   String
  sourceId    String?
  source      JobSource? @relation("FairSource", fields: [sourceId], references: [id])

  // 招聘会信息
  title       String
  theme       String   @default("general")
  startAt     DateTime
  endAt       DateTime
  venue       String
  city        String
  address     String?
  mapImageUrl String?
  description String?
  coverImageUrl String?

  // 数据快照(由同步任务定期回填,只是展示用,非真相之源)
  companyCount Int @default(0)
  jobCount     Int @default(0)
  viewCount    Int @default(0)

  // 审核/发布
  reviewStatus  String @default("pending")
  publishStatus String @default("draft")
  reviewedBy    String?
  reviewedAt    DateTime?
  rejectReason  String?

  syncTime  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies FairCompany[]
  zones     FairZone[]

  @@unique([sourceOrgId, externalId])
  @@index([sourceOrgId])
  @@index([sourceId])
  @@index([theme])
  @@index([reviewStatus, publishStatus])
  @@index([startAt])
}

// ── FairCompany ───────────────────────────────────────────────────────────────
// 参展企业。仅作"招聘会的子卡片"展示,不与 Job 表强关联
// (Job 是岗位级别,FairCompany 是公司级别;招聘会场景下两表通过 sourceUrl
// 链接,不强 FK,因为外部数据源未必同步给我们企业-岗位的映射)。

model FairCompany {
  id        String   @id @default(cuid())
  jobFairId String
  jobFair   JobFair  @relation(fields: [jobFairId], references: [id], onDelete: Cascade)

  name        String
  logoUrl     String?
  industry    String?  // 例 'tech' / 'finance' / 'manufacturing'
  scale       String?  // '<50' / '50-500' / '500-2000' / '>2000'
  description String?
  sourceUrl   String?  // 跳走的对方平台企业页

  // 招聘类型标签(逗号分隔字符串,SQLite 无原生 array)
  hiringTags  String   @default("")

  jobsCount   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([jobFairId])
}

// ── FairZone ──────────────────────────────────────────────────────────────────
// 创新展区 / 主题展区,对应秒哒 kiosk/22 的 6 卡(广州市 AI 智能网联汽车 等)。
// 校企合作场景下也用此表挂"现场服务入口" / "创新展区"。

model FairZone {
  id        String   @id @default(cuid())
  jobFairId String
  jobFair   JobFair  @relation(fields: [jobFairId], references: [id], onDelete: Cascade)

  name          String
  category      String?  // 'innovation' / 'service' / 'campus_corp_topic'
  city          String?  // 城市/区,例 '广州市'(展区分布按地市)
  description   String?
  coverImageUrl String?
  sortOrder     Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobFairId])
  @@index([category])
}

// ── SyncLog ───────────────────────────────────────────────────────────────────
// 每次数据同步（手动导入 / Webhook 接收 / API 拉取）的摘要记录。
// 供 Partner 后台 /sync-logs 页面展示；Admin 走 AuditLog 详查。
//
// dataType:  'job' | 'fair'
// syncMode:  'manual' | 'webhook' | 'api' | 'excel'
// result:    'success' | 'partial' | 'failed'

model SyncLog {
  id           String    @id @default(cuid())
  sourceId     String
  source       JobSource @relation(fields: [sourceId], references: [id])
  orgId        String
  dataType     String
  syncMode     String
  totalCount   Int       @default(0)
  addedCount   Int       @default(0)
  updatedCount Int       @default(0)
  dupCount     Int       @default(0)
  errorCount   Int       @default(0)
  errorFields  String    @default("[]")
  errorDetail  String?
  result       String
  createdAt    DateTime  @default(now())

  @@index([orgId])
  @@index([sourceId])
  @@index([createdAt])
}

// ── ImportBatch ───────────────────────────────────────────────────────────────
// Excel / CSV 文件导入的批次记录。
//
// dataType:  'job' | 'fair'
// status:    'pending' | 'confirmed' | 'cancelled' | 'failed'
// mappingJson: 字段映射规则 { standardField: columnHeader }

model ImportBatch {
  id          String    @id @default(cuid())
  sourceId    String
  source      JobSource @relation(fields: [sourceId], references: [id])
  orgId       String
  dataType    String
  fileName    String
  totalRows   Int       @default(0)
  validRows   Int       @default(0)
  invalidRows Int       @default(0)
  dupRows     Int       @default(0)
  status      String    @default("pending")
  mappingJson String    @default("{}")
  createdBy   String
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  records ImportRecord[]

  @@index([orgId])
  @@index([sourceId])
  @@index([status])
}

// ── ImportRecord ──────────────────────────────────────────────────────────────
// Excel 导入批次中每一行的解析结果。
//
// status: 'ok' | 'invalid' | 'dup'

model ImportRecord {
  id          String      @id @default(cuid())
  batchId     String
  batch       ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  rowIndex    Int
  rawDataJson String      @default("{}")
  mappedJson  String      @default("{}")
  status      String
  errorsJson  String      @default("[]")
  externalId  String?
  createdAt   DateTime    @default(now())

  @@index([batchId])
  @@index([status])
}

// ── FieldMappingRule ────────────────────────────────────────────────────────────
// T1:每个数据源(sourceId)× dataType 保存一份可复用的字段映射规则,
// 让合作机构二次 Excel 导入时自动回填上次映射,无需重复手工映射列。
//
// mappingJson: { standardField: excelColumnHeader }  与 ImportBatch.mappingJson 同形状。
// 一个 (sourceId, dataType) 至多一条;confirmExcelImport 成功后 upsert 更新为最近一次映射。
//
// 合规(CLAUDE.md §10/§11):只存"标准字段 → Excel 列名"的映射结构,
// 不存任何行数据 / 求职者 PII;敏感列在 preview 阶段已被拦截,不可能进入此映射。

model FieldMappingRule {
  id          String    @id @default(cuid())
  sourceId    String
  source      JobSource @relation(fields: [sourceId], references: [id])
  orgId       String
  dataType    String    // 'job' | 'fair'
  mappingJson String    @default("{}")
  updatedBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([sourceId, dataType])
  @@index([orgId])
  @@index([sourceId])
}

// ── AiResumeResult ─────────────────────────────────────────────────────────────
// HIGH-6:AI 解析 / 优化结果持久化。
//
// 之前 ai.service.ts 用进程内 Map(parseStore / optimizeStore)存结果,
// API 重启或多实例后 GET /resume/records/:taskId 直接 404。改为落库:
//   - taskId + kind 唯一(一个 taskId 最多一条 parse + 一条 optimize)
//   - kind:'parse' | 'optimize'
//   - status:复用 AiTaskStatus('pending' | 'processing' | 'completed' | 'failed')
//   - payloadJson:序列化后的 ParseResumeOutput / OptimizeResumeOutput
//     (只含诊断评分 / 优化模块文本,不含简历原文 / 候选人 PII)
//
// 合规约束(CLAUDE.md §11):AI 结果仅服务求职者本人,不推送企业,不做候选人推荐。
// 注:本表沿用现有命名风格(payloadJson 同 AuditLog;cuid 主键)。

model AiResumeResult {
  id         String   @id @default(cuid())
  taskId     String
  kind       String   // 'parse' | 'optimize'
  status     String   // AiTaskStatus
  payloadJson String  @default("{}")
  provider   String
  endUserId  String?
  endUser    EndUser? @relation(fields: [endUserId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  // 留存治理(CLAUDE.md §11「不长期保存简历」):简历派生结果到期即清理。
  // 迁移前历史行 expiresAt 为 null:读取路径与 cron 清理均按"已过期"处理
  // (不可读 + 会被删),不让无留存窗口的历史简历派生数据长期留存。
  expiresAt  DateTime?

  @@unique([taskId, kind])
  @@index([taskId])
  @@index([endUserId])
  @@index([expiresAt])
}

model AuditLog {
  id         String  @id @default(cuid())
  actorId    String?
  actor      User?   @relation(fields: [actorId], references: [id])
  actorRole  String  // 冗余记录,actor 被禁用后仍可追溯
  action     String  // '<resource>.<verb>'
  targetType String
  targetId   String?
  payloadJson String @default("{}")   // 动作上下文(请求 body 摘要 / 旧值 / 新值)
  ipAddress  String?
  userAgent  String?
  requestId  String?  // 关联 RequestIdMiddleware 的 X-Request-Id
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// ── AdAsset ───────────────────────────────────────────────────────────────────
// 待机宣传屏素材(一期)。仅管理员后台上传、管理。
//
// 合规边界(CLAUDE.md §2/§8):
//   - 这是"线下一体机运营"广告位,不属招聘闭环,允许做
//   - 素材文案禁止出现"一键投递 / 立即投递 / 平台投递"等违规词(上传前端 + 审核把关)
//   - 前台统一称"待机宣传屏",不强调"广告平台"属性
//
// 物理文件经 LocalFileStorage 落地(purpose='screensaver_ad'),Kiosk 经
// HMAC 签名 URL(较长 TTL)拉取;Kiosk 端缓存 key 用 sha256 / id,绝不用签名 URL。
//
// type:   'image' | 'video'
// source: 'uploaded' | 'ai_generated'(二期 AI 文生图产物,管理员确认后才入库)
// status: 'active' | 'disabled'
// durationSec:图片停留秒数 / 视频时长(秒)
model AdAsset {
  id             String   @id @default(cuid())
  type           String   // 'image' | 'video'
  title          String
  storageKey     String   @unique
  mimeType       String
  sizeBytes      Int
  sha256         String
  width          Int?
  height         Int?
  durationSec    Int      @default(8)
  source         String   @default("uploaded") // 'uploaded' | 'ai_generated'
  aiGenerationId String?
  status         String   @default("active")    // 'active' | 'disabled'
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  playlistItems AdPlaylistItem[]

  @@index([status])
  @@index([type])
  @@index([deletedAt])
}

// ── AdPlaylist ────────────────────────────────────────────────────────────────
// 播放方案:一组按顺序轮播的素材,可绑定到一个或多个终端。
// status: 'active' | 'disabled'(禁用后绑定它的终端拉取不到内容,屏保不触发)
model AdPlaylist {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("active")
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  items   AdPlaylistItem[]
  configs TerminalScreensaverConfig[]

  @@index([status])
}

// ── AdPlaylistItem ────────────────────────────────────────────────────────────
// 播放方案与素材的关联(含排序与单项开关)。一期排序用 order 整数(上移/下移)。
model AdPlaylistItem {
  id         String     @id @default(cuid())
  playlistId String
  playlist   AdPlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  assetId    String
  asset      AdAsset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  order      Int        @default(0)
  enabled    Boolean    @default(true)
  createdAt  DateTime   @default(now())

  @@unique([playlistId, assetId])
  @@index([playlistId])
  @@index([assetId])
}

// ── TerminalScreensaverConfig ─────────────────────────────────────────────────
// 每个终端的待机配置:是否启用、无操作多少秒进入屏保、绑定哪个播放方案。
//
// terminalId 为自由字符串(不强 FK 到 Terminal):配置可在终端注册前预置,
// 与 printer-status 端点一致按 terminalId 字符串查找。
// enabled=false 或未绑定 playlist → Kiosk 拉取返回 enabled:false,不进屏保。
model TerminalScreensaverConfig {
  id             String      @id @default(cuid())
  terminalId     String      @unique
  enabled        Boolean     @default(false)
  idleTimeoutSec Int         @default(180)
  playlistId     String?
  playlist       AdPlaylist? @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  updatedBy      String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([playlistId])
}
