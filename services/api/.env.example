# services/api 环境变量样板。
# 复制为 .env(.env 已被 git ignore),按需修改。
# 生产环境的密钥必须从外部 secrets manager 注入,不要 commit。

# ── 数据库 ───────────────────────────────────────────────────────────────────
# Dev:本地 SQLite
DATABASE_URL="file:./prisma/dev.db"
# Prod 示例(Postgres):
# DATABASE_URL="postgresql://user:pass@host:5432/ai_job_print"

# ── JWT(Auth Phase 0a)─────────────────────────────────────────────────────
# 至少 16 字符;生产用 ≥ 64 字符的随机串
JWT_SECRET="dev-only-secret-please-replace-in-prod-min-16-chars"

# ── Terminal Agent(Phase 8.2)──────────────────────────────────────────────
# 终端注册管理凭证(64 hex)
TERMINAL_ADMIN_SECRET="replace-with-64-hex-chars-from-openssl-rand"
# 终端动作 token 签名密钥(64 hex)
TERMINAL_ACTION_TOKEN_SECRET="replace-with-64-hex-chars-from-openssl-rand"

# ── BE-1 文件签名(P0 W1)──────────────────────────────────────────────────
# HMAC-SHA256 签名密钥,≥ 32 字符
# 生产生成:openssl rand -hex 64
FILE_SIGNING_SECRET="dev-file-signing-secret-replace-in-prod-must-be-min-32-chars"

# 文件物理落盘根目录;空则默认 cwd/storage
# Windows 示例:FILE_STORAGE_DIR="C:\\storage"
FILE_STORAGE_DIR=""

# ── API 端口 ────────────────────────────────────────────────────────────────
PORT=3010
