# services/api 环境变量样板。
# 复制为 .env(.env 已被 git ignore),按需修改。
# 生产环境的密钥必须从外部 secrets manager 注入,不要 commit。

# ── 数据库 ───────────────────────────────────────────────────────────────────
# Dev:本地 SQLite
DATABASE_URL="file:./prisma/dev.db"
# PostgreSQL(第四阶段,生产):DATABASE_URL="postgresql://user:pass@host:5432/db"
#   运行时按协议自动选 adapter(file:→SQLite / postgresql://→PG);
#   NODE_ENV=production 时会硬拒绝 file: SQLite,避免并发写入场景误用本地库。
#   PG 部署/迁移命令用 POSTGRES_URL(避免误连开发库),见 docs/device/postgres-operations.md
#POSTGRES_URL=
# Prod 示例(Postgres):
# DATABASE_URL="postgresql://user:pass@host:5432/ai_job_print"

# ── JWT(Auth Phase 0a)─────────────────────────────────────────────────────
# 至少 16 字符;生产用 ≥ 64 字符的随机串
JWT_SECRET="dev-only-secret-please-replace-in-prod-min-16-chars"

# ── Terminal Agent(Phase 8.2)──────────────────────────────────────────────
# 终端注册管理凭证(64 hex)
TERMINAL_ADMIN_SECRET="replace-with-64-hex-chars-from-openssl-rand"
# 终端动作 token 签名密钥(64 hex)
TERMINAL_ACTION_TOKEN_SECRET="replace-with-64-hex-chars-from-openssl-rand"

# ── BE-1 文件签名(P0 W1)──────────────────────────────────────────────────
# HMAC-SHA256 签名密钥,≥ 32 字符
# 生产生成:openssl rand -hex 64
FILE_SIGNING_SECRET="dev-file-signing-secret-replace-in-prod-must-be-min-32-chars"

# 文件物理落盘根目录;空则默认 cwd/storage
# Windows 示例:FILE_STORAGE_DIR="C:\\storage"
FILE_STORAGE_DIR=""

# ── 对象存储后端选择(本地 / 腾讯云 COS)───────────────────────────────────────
# local(默认):文件落本地 FS,内容经 API /files/:id/content 代理签名 URL。
# cos:文件落腾讯云 COS,下载/预览/上传走 COS 预签名 URL。
#   选 cos 时,下面 TENCENT_COS_* 四项必填,否则 API 启动报错。
FILE_STORAGE_DRIVER=local

# ── 腾讯云 COS(对象存储)────────────────────────────────────────────────────
# ★ SecretId / SecretKey 仅服务端持有,严禁写入前端 / 提交真实值到仓库。★
# 来源:腾讯云控制台 → 访问管理 CAM → 访问密钥。
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
# 主业务私有桶(统一桶,按 objectKey 前缀分类,不按端拆桶)
TENCENT_COS_BUCKET=yitiji-prod-private-1257025684
TENCENT_COS_REGION=ap-guangzhou
# 签名 URL 有效期(秒);合规上限 1800(30 分钟),超过会被 clamp。
TENCENT_COS_SIGN_URL_EXPIRES_SECONDS=1800

# ── BE-8 凭证加密(W3)──────────────────────────────────────────────────────
# JobSource.encryptedCredential 用 AES-256-GCM 加密,密钥从这里读
# scrypt 派生为固定 32 字节 key,所以输入只要 ≥ 32 字符即可
# 生产生成:openssl rand -hex 64
SECRET_ENCRYPTION_KEY="dev-secret-encryption-key-replace-in-prod-min-32-chars"

# ── Redis / BullMQ(W8 API pull worker)────────────────────────────────────
# 有此变量时 W8 BullMQ worker 走真实 Redis 队列；无此变量时自动降级 inline 模式(仅 dev)。
# Dev 本地起 Redis：docker run -d -p 6379:6379 redis:7-alpine
# 生产必配，不允许在生产中使用 inline 降级。
# redis://:password@host:6379/0  （带密码）
# redis://localhost:6379          （无密码，本地）
REDIS_URL="redis://localhost:6379"

# ── C 端会员短信验证码──────────────────────────────────────────────────────
# dev 默认:不配置 SMS_PROVIDER 时使用 log,验证码只打印在服务端日志。
# prod 必配:SMS_PROVIDER=tencent。生产环境禁止 SMS_PROVIDER=log。
# 当前代码已接入腾讯云短信真实 SendSms（TC3-HMAC-SHA256 签名）。上线还需:① 短信签名/模板
# 审核通过拿到 SignName/TemplateId/SDKAppID ② 真实 CAM 短信密钥进服务端 env ③ 真号 E2E 验收;
# 三者齐备后再置 SMS_PROVIDER=tencent。审核通过前生产强制禁假发送（resolveSmsProvider）。
SMS_PROVIDER=log

# 腾讯云短信配置（SMS_PROVIDER=tencent 时必填）：
# 来源:腾讯云控制台 → 短信 SMS → 应用管理 / 国内短信 → 签名管理 / 正文模板管理,
# 以及访问管理 CAM → 访问密钥。密钥只放服务端 env,严禁提交真实值。
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_REGION=ap-guangzhou
# 可选：验证码有效期分钟（对应模板 {2} 参数）。留空=单参数模板（仅 {1}=验证码）；
# 填数字=双参数模板（{1}=验证码 {2}=有效期分钟），值须与实际验证码 TTL 一致。
TENCENT_SMS_CODE_EXPIRE_MINUTES=
# 可选：短信 API Host（默认 sms.tencentcloudapi.com）；本地 stub 联调可指向 127.0.0.1:port。
# TENCENT_SMS_HOST=
# 可选：SendSms 请求超时毫秒（默认 10000）。
# TENCENT_SMS_TIMEOUT_MS=10000

# ── API 端口 ────────────────────────────────────────────────────────────────
PORT=3010

# ── CORS（生产环境必配）────────────────────────────────────────────────────────
# 生产环境指定允许的前端 origin，多个用逗号分隔，不要带尾部斜线。
# 开发环境（NODE_ENV != production）自动允许任意 origin，此变量无效。
# CORS_ALLOWED_ORIGINS="https://kiosk.example.com,https://admin.example.com"

# ── 腾讯 TRTC 对话式 AI（Phase 9）────────────────────────────────────────────
# ★★★ 更换腾讯云应用 / 试用到期后切换：只改下面这些 env 后重启 API 即可，无需改任何代码。★★★
#   AI 数字人（语音）的全部凭证与接口都从 env 读取，代码已冻结、不需要也不应该改动。
#   过期换新应用时，按腾讯云控制台重新填：
#     1) TRTC_SDK_APP_ID / TRTC_SDK_SECRET_KEY  ← TRTC 控制台 → 应用管理（新 SDKAppID/SDKSecretKey）
#     2) TENCENT_SECRET_ID / TENCENT_SECRET_KEY ← CAM 访问密钥（调 StartAIConversation/StopAIConversation）
#     3) TRTC_TTS_APP_ID                        ← 语音合成 TTS 的 AppId（与 SDKAppID 不是同一个）
#     4) TRTC_LLM_API_KEY / TRTC_LLM_API_URL    ← 数字人对话用的大模型（可换任意 OpenAI 兼容厂商）
#   改完执行：services/api 目录下重启（pnpm dev / 重启服务）。文字版助手另见后台「AI模型配置」在线改。
#
# TRTC 应用凭证：腾讯云 TRTC 控制台 → 应用管理 → SDKAppID / SDKSecretKey
TRTC_SDK_APP_ID=
TRTC_SDK_SECRET_KEY=
# 腾讯云 API 凭证：访问管理 CAM → 访问密钥（用于调 StartAIConversation / StopAIConversation）
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TRTC_REGION=ap-guangzhou
# 数字人对话用大模型（OpenAI 兼容协议）。换厂商时同时改 TYPE/MODEL/API_KEY/API_URL：
#   DeepSeek 示例：TYPE=openai / MODEL=deepseek-chat / API_URL=https://api.deepseek.com/v1/chat/completions
#   腾讯混元示例：TYPE=tencent / MODEL=hunyuan-turbo（走腾讯云内置，无需 API_URL）
TRTC_LLM_TYPE=openai
TRTC_LLM_MODEL=deepseek-chat
TRTC_LLM_API_KEY=
TRTC_LLM_API_URL=https://api.deepseek.com/v1/chat/completions
# TTS 配置：腾讯云 AI 对话的 tencent TTS 需要单独的 AppId，不是 TRTC_SDK_APP_ID。
TRTC_TTS_TYPE=tencent
TRTC_TTS_APP_ID=
TRTC_TTS_VOICE=1008
TRTC_TTS_SPEED=0
TRTC_TTS_VOLUME=5
TRTC_TTS_PRIMARY_LANGUAGE=1
# 完全自定义 TTS JSON 可选（优先级最高）：
# TRTC_TTS_CONFIG_JSON=
# AI 人设系统提示词（可选，留空用默认就业顾问人设）
TRTC_SYSTEM_PROMPT=

# ── AI 助手文字对话大模型（管理员后台「AI模型配置」可在线改）──────────────────
# 默认 vendor=deepseek。首次启动若未在后台配置，会回退读取下面这个 key
# （未设置则读 TRTC_LLM_API_KEY）。后台保存后以加密落盘的配置为准。
# 支持厂商：deepseek / qwen（通义千问）/ minimax，均兼容 OpenAI 接口。
AI_LLM_API_KEY=

# ── AI 简历诊断 provider（Phase 1B）────────────────────────────────────────────
# 简历「解析 / 诊断」走哪个 provider（与上面 AI 助手对话的在线配置相互独立）。
#   mock（默认）：返回演示报告，前端显示「演示数据」横幅，不读取文件内容。
#   llm：真实诊断——服务端先提取简历文本（DOCX/PDF，见下方 OCR 区），再调上面「AI模型配置」
#        在线配置的大模型（DeepSeek / 通义 / MiniMax，OpenAI 兼容）生成结构化报告；
#        提取失败或模型未配置 / 未启用时明确失败，**绝不 fallback 演示报告**。
#   openai / claude / qwen / zhipu / local：占位 stub，未接入。
# 非法值会让 API 启动报错（AI_PROVIDER_INVALID），不静默回退。
AI_PROVIDER=mock

# ── 简历派生结果留存（CLAUDE.md §11「不长期保存简历」）────────────────────────
# AI 解析/优化结果（AiResumeResult）的留存窗口（小时）。到期由每小时 cron 硬删。
# 接入真实 AI provider（before/after 可能含简历摘录）后建议按需调小。默认 24。
AI_RESUME_RESULT_TTL_HOURS=24

# ── 简历文件文字提取 OCR（Phase 1A 底座 → Stage 3 真实接入）─────────────────
# 简历提取：DOCX 正文 + 文本型 PDF 文字层为纯 JS 提取，无需任何 env。
# 「图片 / 扫描件 PDF 简历」走 OCR；此处选择 OCR provider：
#   disabled（默认）：图片/扫描件诚实返回 OCR_NOT_CONFIGURED，绝不假识别。
#   baidu（Stage 3 已接真）：百度智能云通用文字识别（高精度版 accurate_basic）。
#   tencent：占位（保留扩展位，未接真实 API）。
# 非法值会让 API 启动报错（OCR_PROVIDER_INVALID），不静默回退。
OCR_PROVIDER=disabled

# 百度智能云 OCR（OCR_PROVIDER=baidu 时必填）：
# ★ API Key / Secret Key 仅服务端持有，严禁写入前端 / 提交真实值到仓库 / 出现在日志。★
# 来源：百度智能云控制台 → 文字识别 → 应用列表（需开通「通用文字识别 高精度版」）。
# 服务端用密钥换 access_token（约 30 天，内存缓存自动刷新）；识别在服务端读 buffer
# 后调用，图片与识别原文不落盘、不写日志、不进审计。
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
# 可选限制（留空用默认）：单图上限 6MB / 单请求超时 15s / 并发 2（对齐免费档 QPS）/
# 扫描件最多识别 3 页（1–10）：
#BAIDU_OCR_MAX_IMAGE_BYTES=6291456
#BAIDU_OCR_TIMEOUT_MS=15000
#BAIDU_OCR_MAX_CONCURRENCY=2
#OCR_PDF_MAX_PAGES=3

# ── 模拟面试语音转写 ASR（2C+）────────────────────────────────────────────────
# disabled（默认）：语音转写不启用，前台自动回退文字输入（文字兜底是硬路径）。
# tencent（推荐，与数字人/TRTC 同腾讯云生态）：一句话识别 SentenceRecognition（≤60s）。
#   默认复用上方 TRTC 的 TENCENT_SECRET_ID/TENCENT_SECRET_KEY（对话式 AI 密钥自带语音权限）；
#   如需独立密钥可设 TENCENT_ASR_SECRET_ID / TENCENT_ASR_SECRET_KEY。TC3 签名全在服务端。
# baidu（备选）：百度「短语音识别」标准版，需单独开通并配 BAIDU_ASR_API_KEY/SECRET_KEY。
# 音频仅内存转发转写，不落盘、不写日志、不持久化。
ASR_PROVIDER=disabled
#TENCENT_ASR_SECRET_ID=
#TENCENT_ASR_SECRET_KEY=
BAIDU_ASR_API_KEY=
BAIDU_ASR_SECRET_KEY=
#BAIDU_ASR_TIMEOUT_MS=20000

# 腾讯云 OCR（OCR_PROVIDER=tencent 且二期接真实接口时必填）：
# ★ SecretId / SecretKey 仅服务端持有，严禁写入前端 / 提交真实值到仓库。★
# 来源：腾讯云控制台 → 访问管理 CAM → 访问密钥。识别在服务端读 buffer 后调用，
# 不把简历图片 URL / 识别原文写入日志或审计。
TENCENT_OCR_SECRET_ID=
TENCENT_OCR_SECRET_KEY=
TENCENT_OCR_REGION=ap-guangzhou

# ── 待机宣传屏(Screensaver / 广告位)──────────────────────────────────────────
# 素材物理文件复用 FILE_STORAGE_DIR + FILE_SIGNING_SECRET(见上),无需额外密钥。
# 素材大小 / 视频时长上限(留空用默认值)：
AD_ASSET_MAX_IMAGE_MB=10
AD_ASSET_MAX_VIDEO_MB=100
AD_ASSET_MAX_VIDEO_SEC=120
# 外部视频直链白名单(逗号分隔 host,如 cdn.example.com,videos.gov.cn)。
# 留空 = 放行所有通过私网/内网检查的公网 HTTPS .mp4/.webm 直链;
# 配置后只允许名单内域名,用于收紧外链来源。
# ALLOWED_EXTERNAL_VIDEO_HOSTS=

# ── AI 文生图海报(二期能力,一期 stub)────────────────────────────────────────
# 一期保持 disabled：所有生成接口返回 400 AI_POSTER_NOT_ENABLED,不产生任何外部费用。
# 二期接真实供应商(如 wanx 通义万相 / cogview 智谱)时改此值并填 API Key。
AI_IMAGE_PROVIDER=disabled
AI_IMAGE_API_KEY=
# 每日生成上限(留空表示不限制；二期生效)
AI_IMAGE_DAILY_LIMIT=

# ── 支付会话签名密钥（打印建单后签发短期 payment session token）──────────────
# 生产门禁强制：NODE_ENV=production 时必须存在且 >= 32 字符，且不得复用
# JWT_SECRET / FILE_SIGNING_SECRET（W-A 补样板条目；此前门禁已强制但样板缺失）。
PAYMENT_SESSION_SECRET="dev-payment-session-secret-replace-in-prod-min-32-chars"

# ── 线上扫码支付（C5-2 沙箱底座 + C5-6 真实渠道）─────────────────────────────
# PAYMENT_PROVIDER 取值（逗号分隔可多通道，如 wechat,alipay）：
#   （留空/disabled，默认）：线上支付关闭，pay 端点返回 ONLINE_PAYMENT_DISABLED，不伪装可支付。
#   sandbox：沙箱测试通道 —— 假 scheme 动态码 + 模拟回调端点，零外部费用、无真实资金。
#            仅开发/联调可用；NODE_ENV=production 配 sandbox 会启动失败（生产运行时门禁）；
#            不得与 wechat/alipay 混配（PAYMENT_PROVIDER_SANDBOX_EXCLUSIVE）。
#   wechat / alipay：C5-6 真实资金渠道（微信 Native 动态码 / 支付宝当面付 precreate）。
#            任一关键配置缺失即启动失败（fail-closed），绝不带残缺配置收真钱。
PAYMENT_PROVIDER=sandbox
# 沙箱回调验签密钥（PAYMENT_PROVIDER=sandbox 时必填，>=16 字符，缺失/过短启动失败）。
# ★ 仅服务端持有；前端 / Kiosk / Terminal Agent 一律不得保存。★
SANDBOX_PAYMENT_SECRET="dev-sandbox-payment-secret-replace-me"
# 动态码有效期 / 订单超时关单时限（秒，留空用默认 300 / 900；范围 30–86400）：
#PAYMENT_QR_TTL_SECONDS=300
#PAYMENT_ORDER_TTL_SECONDS=900

# ── C5-6 真实渠道公共配置（启用 wechat / alipay 时必填）─────────────────────
# 支付回调可达的公网 base（生产必须 https）；回调路径固定为
#   {base}/api/v1/payment/callback/wechat 与 {base}/api/v1/payment/callback/alipay
#PAYMENT_NOTIFY_BASE_URL=https://your-domain.example.com

# ── 微信支付 Native（APIv3，公钥模式）——全部只存服务端，禁止进仓库/前端/Agent ──
# ★ 下列均为占位符；真实值只在部署环境注入，绝不提交到版本库。★
#WECHAT_PAY_MCHID=
#WECHAT_PAY_APPID=
#WECHAT_PAY_MCH_SERIAL_NO=
# 商户 API 私钥：二选一 —— 内联 PEM（\n 转义）或服务器本地文件路径
#WECHAT_PAY_PRIVATE_KEY_PEM=
#WECHAT_PAY_PRIVATE_KEY_PATH=/path/to/apiclient_key.pem
# APIv3 密钥（32 字符；回调 resource 解密）
#WECHAT_PAY_APIV3_KEY=
# 微信支付公钥（回调验签）+ 公钥 ID（回调 Wechatpay-Serial 必须命中）
#WECHAT_PAY_PUBLIC_KEY_PEM=
#WECHAT_PAY_PUBLIC_KEY_PATH=/path/to/wechatpay_public_key.pem
#WECHAT_PAY_PUBLIC_KEY_ID=
# 渠道网关（默认官方，一般不用改）：
#WECHAT_PAY_API_BASE=https://api.mch.weixin.qq.com

# ── 支付宝当面付（RSA2）——全部只存服务端，禁止进仓库/前端/Agent ──────────────
#ALIPAY_APP_ID=
# 应用私钥：二选一 —— 内联 PEM（\n 转义）或服务器本地文件路径
#ALIPAY_APP_PRIVATE_KEY_PEM=
#ALIPAY_APP_PRIVATE_KEY_PATH=/path/to/app_private_key.pem
# 支付宝公钥（响应/notify 验签）
#ALIPAY_PUBLIC_KEY_PEM=
#ALIPAY_PUBLIC_KEY_PATH=/path/to/alipay_public_key.pem
# 网关（默认官方，一般不用改）：
#ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do

# ── 出纸门控（paid 后才 claim 出纸；C5-3 引入，C5-6 起生产必须显式声明）───────
# =true：Terminal Agent 只领取「已 paid 或无关联 Order（seed/历史）」的 pending 任务；
#        付费单在支付前保持 pending 但不出纸。启用 wechat/alipay 真实收款时必须为 true。
# =false：保持 C5-3 前行为（未支付单也可被领取出纸），仅适用于线下收款运营模型。
# NODE_ENV=production 时必须显式写 true 或 false（缺省会启动失败：
# PRODUCTION_PAID_BEFORE_CLAIM_UNDECLARED）；开发/CI 缺省视为关闭。
#PRINT_REQUIRE_PAID_BEFORE_CLAIM=false

# ── 退款自动收敛 cron（W-C；关闭 W-B 的运营卡单风险）────────────────────────
# =true：每 10 分钟扫真实渠道 pending 退款（wechat 受理中/结果不可知），走与人工
# 重复退款完全相同的幂等查证路径自动收敛（渠道 out_refund_no 幂等，绝不二次出款）。
# 默认关闭：未接真实渠道的环境（sandbox 退款同步完成不留 pending）无需开启。
# 接入 wechat/alipay live 后建议 =true。
#REFUND_AUTO_CONVERGE_ENABLED=false
