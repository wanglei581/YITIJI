# Codex temp
.codex-tmp/

# Dependencies
node_modules
.pnpm-store

# Build output
dist
*.tsbuildinfo
apps/*/vite.config.js
apps/*/vite.config.d.ts

# Generated artifacts (manual exports / presentations)
outputs/

# One-off root-level design previews should live under docs/design/ instead.
/kiosk-home*.html

# Environment
.env
.env.local
.env.*.local
# 忽略所有 .env.* 环境文件（可能含密钥）；下方显式放行示例/模板
.env.*
!.env.example
!**/.env.example
!.env.template
!**/.env.template
# .env 备份文件不入库（可能含密钥）；保留 .env.example / .env.template 跟踪
.env.bak*
*.env.bak*
.env.*.bak
services/**/.env.bak-*

# Editor
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Archives（旧项目参考包，不入仓库）
*.zip

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Browser verification artifacts
.playwright-cli/
test-results/

# Temp
.tmp
mavis-workspace/
.mavis/
.opencode/

# Local collaboration/tool workspaces (keep locally, do not track)
# 注：.ccg/spec 是正式工程规范，保持跟踪，不在此列
/.ccg/commander/
/.ccg/tasks/
/.product-pm/
/.workbuddy/
/.superpowers/
/.worktrees/
/opc-doc/
/其他文档/

# Runtime-generated API state（含 ai-model-config.json 的 apiKeyEncrypted 等密钥材料，不入仓库）
services/api/data/

# docs 下的二进制文档（如机器生成 / 外部 .docx）不入库，结论沉淀为同名 .md
docs/**/*.docx
services/api/prisma/ci-test.db
services/api/src/generated/prisma-pg/

# deliverables 下的二进制成品（演示 PPT / PDF / DOCX）不入库，防止误提交撑大历史；文本类（.md / .html）仍可入库
/deliverables/**/*.pdf
/deliverables/**/*.pptx
/deliverables/**/*.docx
