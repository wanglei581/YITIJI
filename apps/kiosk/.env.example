# ============================================================
# Kiosk 环境变量示例
# 复制为 .env.local 并按需修改（.env.local 不提交到版本控制）
# ============================================================

# API 运行模式
# mock  — 使用本地 mock 数据，无需后端（默认，仅供本地开发/演示）
# http  — 调用真实后端，需同时配置 VITE_API_BASE_URL
# ⚠ 生产构建强制 http：vite.config.ts 在 production build 时若 VITE_API_MODE≠http 会直接报错，
#   防止把 mock 静态假数据打进生产产物（详见 docs/progress/project-full-audit-...-2026-06-14.md P0）。
VITE_API_MODE=mock

# 后端 API 基础路径（VITE_API_MODE=http 时必须配置）
# 本地开发示例：
# VITE_API_BASE_URL=http://localhost:3000/api/v1
# 局域网/手机访问建议使用相对路径，由 Vite dev server 代理到 API：
# VITE_API_BASE_URL=/api/v1
# 生产环境通过 CI/CD 注入，不要把生产地址提交到此文件
# VITE_API_BASE_URL=

# Vite dev server 代理目标，用于 fetch('/api/v1/...') 这类同源请求。
# 本项目 API 示例端口是 3010；如果你的后端实际跑 3000，请改成 http://localhost:3000
VITE_API_PROXY_TARGET=http://localhost:3010

# 腾讯 TRTC 语音通话（Phase 9）
# true = AI 助手页进入即自动语音通话；false（默认）= 文字模式
# 启用前需：① 安装 trtc-sdk-v5  ② 配置后端 TRTC_* 凭证
# 生产构建默认必须为 true；若确认为纯文字助手部署，需显式设置 VITE_ALLOW_TEXT_ONLY_ASSISTANT=true。
VITE_USE_TRTC_CALL=false
# VITE_ALLOW_TEXT_ONLY_ASSISTANT=

# 终端标识（打印/扫描任务创建与打印机状态强依赖）
# 填写本机注册后的 terminalId（格式：cuid，由后端注册接口返回）
# 未配置时打印预览页显示"设备未就绪"
# ⚠️ 生产构建必填（vite.config 构建期硬门禁，文字助手模式不豁免；Task 11）
# VITE_TERMINAL_ID=

# 打印机显示名称（展示在打印设置页，不影响实际打印逻辑）
# 从终端 heartbeat 配置中读取；未配置时显示"已配置打印机"
# 禁止硬编码具体型号（CLAUDE.md §3）
# VITE_PRINTER_NAME=

# 本机 Terminal Agent QR 登录桥接服务（仅 127.0.0.1）
# 扫码登录 create/claim 经由此本机服务转发，避免把 agentToken 暴露给浏览器包
# VITE_TERMINAL_AGENT_LOCAL_URL=http://127.0.0.1:9527

# 本地网桥静态令牌（扫码登录 create/claim + U 盘导入共用），必须与本机 Terminal Agent
# 配置的 localApiBridgeToken 一致；安装时随本机 Kiosk 构建一起下发（不走网络协商）
# 未配置时：扫码登录 create/claim 会 403（提示改用手机号登录）；"U盘导入" tab 前端直接禁用
# VITE_TERMINAL_AGENT_BRIDGE_TOKEN=

# 二维码给手机打开的 Kiosk 公网/局域网访问基址。
# 未配置时默认使用当前浏览器 window.location.origin；如果 Kiosk 在 localhost 运行，
# 手机无法访问时需要配置为手机可访问的域名或局域网地址。
# VITE_QR_LOGIN_PUBLIC_BASE_URL=

# 展示给手机确认页的本机设备名称；未配置时用当前页面 host
# VITE_TERMINAL_DISPLAY_NAME=

# 会员登录态空闲自动登出阈值（秒），Phase C-1
# 登录后无操作超过该时长自动清空内存会话（忙碌态：打印/扫描/AI/上传 期间暂停计时）
# 未配置时默认 180 秒，与待机宣传屏默认空闲一致
# VITE_KIOSK_LOGOUT_IDLE_SEC=180
