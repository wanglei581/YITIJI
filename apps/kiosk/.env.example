# ============================================================
# Kiosk 环境变量示例
# 复制为 .env.local 并按需修改（.env.local 不提交到版本控制）
# ============================================================

# API 运行模式
# mock  — 使用本地 mock 数据，无需后端（默认）
# http  — 调用真实后端，需同时配置 VITE_API_BASE_URL
VITE_API_MODE=mock

# 后端 API 基础路径（VITE_API_MODE=http 时必须配置）
# 本地开发示例：
# VITE_API_BASE_URL=http://localhost:3000/api/v1
# 局域网/手机访问建议使用相对路径，由 Vite dev server 代理到 API：
# VITE_API_BASE_URL=/api/v1
# 生产环境通过 CI/CD 注入，不要把生产地址提交到此文件
# VITE_API_BASE_URL=

# Vite dev server 代理目标，用于 fetch('/api/v1/...') 这类同源请求。
# 本项目 API 示例端口是 3010；如果你的后端实际跑 3000，请改成 http://localhost:3000
VITE_API_PROXY_TARGET=http://localhost:3010

# 腾讯 TRTC 语音通话（Phase 9）
# true = AI 助手页进入即自动语音通话；false（默认）= 文字模式
# 启用前需：① 安装 trtc-sdk-v5  ② 配置后端 TRTC_* 凭证
VITE_USE_TRTC_CALL=false

# 终端标识（打印页面读取打印机状态用）
# 填写本机注册后的 terminalId（格式：cuid，由后端注册接口返回）
# 未配置时打印预览页显示"设备未就绪"
# VITE_TERMINAL_ID=

# 打印机显示名称（展示在打印设置页，不影响实际打印逻辑）
# 从终端 heartbeat 配置中读取；未配置时显示"已配置打印机"
# 禁止硬编码具体型号（CLAUDE.md §3）
# VITE_PRINTER_NAME=
