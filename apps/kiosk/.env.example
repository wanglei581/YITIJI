# ============================================================
# Kiosk 环境变量示例
# 复制为 .env.local 并按需修改（.env.local 不提交到版本控制）
# ============================================================

# API 运行模式
# mock  — 使用本地 mock 数据，无需后端（默认）
# http  — 调用真实后端，需同时配置 VITE_API_BASE_URL
VITE_API_MODE=mock

# 后端 API 基础路径（VITE_API_MODE=http 时必须配置）
# 本地开发示例：
# VITE_API_BASE_URL=http://localhost:3000/api/v1
# 生产环境通过 CI/CD 注入，不要把生产地址提交到此文件
# VITE_API_BASE_URL=
