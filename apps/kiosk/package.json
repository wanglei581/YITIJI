    "react": "^18.3.1",
    "react-diff-viewer-continued": "^4.2.2",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "trtc-sdk-v5": "^5.17.1"
