    "verify:smart-campus-ui": "node scripts/verify-smart-campus-ui.mjs",
    "verify:member-session-closure": "node scripts/verify-member-session-closure.mjs",
    "verify:prod-build-config": "node scripts/verify-prod-build-config.mjs",
