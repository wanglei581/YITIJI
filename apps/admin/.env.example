# ============================================================
# Admin 环境变量示例
# 复制为 .env.local 并按需修改（.env.local 不提交到版本控制）
# ============================================================

# API 运行模式
# mock  — 使用本地 mock 数据，无需后端（默认，仅供本地开发/演示）
# http  — 调用真实后端，需同时配置 VITE_API_BASE_URL
# ⚠ 生产构建强制 http：vite.config.ts 在 production build 时若 VITE_API_MODE≠http 会直接报错，
#   防止把 mock 假数据打进生产产物（详见 docs/progress/project-full-audit-...-2026-06-14.md P0）。
VITE_API_MODE=mock

# 后端 API 基础路径（VITE_API_MODE=http 时必须配置）
# 本地开发示例：
# VITE_API_BASE_URL=http://localhost:3010/api/v1
# 同源部署示例：
# VITE_API_BASE_URL=/api/v1
# 生产环境通过 CI/CD 注入，不要把生产地址提交到此文件
# VITE_API_BASE_URL=

# Vite dev server 代理目标，用于 fetch('/api/v1/...') 这类同源请求。
VITE_API_PROXY_TARGET=http://localhost:3010
